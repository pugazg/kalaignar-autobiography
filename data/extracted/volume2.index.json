{
  "volume": 2,
  "strategy": "heuristic",
  "totalPages": 608,
  "chapterCount": 77,
  "chapters": [
    {
      "title": "என்னுரை",
      "startPage": 5,
      "endPage": 20,
      "id": "v2-ch01"
    },
    {
      "title": "முதல் பாகம் வெளியிட்ட கதை",
      "startPage": 21,
      "endPage": 26,
      "id": "v2-ch02"
    },
    {
      "title": "மூன்று கடிதங்கள்",
      "startPage": 27,
      "endPage": 36,
      "id": "v2-ch03"
    },
    {
      "title": "அதிர்ச்சியூட்டும் செய்தி",
      "startPage": 37,
      "endPage": 44,
      "id": "v2-ch04"
    },
    {
      "title": "ஒரு கெட்ட வார்த்தை!",
      "startPage": 45,
      "endPage": 53,
      "id": "v2-ch05"
    },
    {
      "title": "சங்கம் சரணம் கச்சாமி!",
      "startPage": 54,
      "endPage": 65,
      "id": "v2-ch06"
    },
    {
      "title": "மாலையும் கயிறும்!",
      "startPage": 66,
      "endPage": 73,
      "id": "v2-ch07"
    },
    {
      "title": "வெண்மணி வேதனை",
      "startPage": 74,
      "endPage": 80,
      "id": "v2-ch08"
    },
    {
      "title": "உறவுகள் - உரிமைகள்",
      "startPage": 81,
      "endPage": 87,
      "id": "v2-ch09"
    },
    {
      "title": "முதல் குரலும் - முதல் பிளவும்",
      "startPage": 88,
      "endPage": 95,
      "id": "v2-ch10"
    },
    {
      "title": "வண்டிப் பெரியார் நிகழ்ச்சி",
      "startPage": 96,
      "endPage": 102,
      "id": "v2-ch11"
    },
    {
      "title": "ஆப்பக்கூடல் ஆபத்து",
      "startPage": 103,
      "endPage": 109,
      "id": "v2-ch12"
    },
    {
      "title": "எங்கிருந்தாலும் வாழ்க!",
      "startPage": 110,
      "endPage": 116,
      "id": "v2-ch13"
    },
    {
      "title": "இயக்கத்தில் சிவாஜி",
      "startPage": 117,
      "endPage": 124,
      "id": "v2-ch14"
    },
    {
      "title": "தியாக தீபங்கள்",
      "startPage": 125,
      "endPage": 139,
      "id": "v2-ch15"
    },
    {
      "title": "நாடறிந்த உண்மை",
      "startPage": 140,
      "endPage": 145,
      "id": "v2-ch16"
    },
    {
      "title": "பரம்பிக்குளம் ஆளியாறு இறுதி ஒப்பந்தம்",
      "startPage": 146,
      "endPage": 153,
      "id": "v2-ch17"
    },
    {
      "title": "இங்கும் அங்கும்",
      "startPage": 154,
      "endPage": 171,
      "id": "v2-ch18"
    },
    {
      "title": "பிரதமரின் தோல்வி!",
      "startPage": 172,
      "endPage": 177,
      "id": "v2-ch19"
    },
    {
      "title": "ஆச்சரியம் காத்திருந்தது!",
      "startPage": 178,
      "endPage": 184,
      "id": "v2-ch20"
    },
    {
      "title": "வீழ்ச்சி தடுக்கப்பட்டது!",
      "startPage": 185,
      "endPage": 192,
      "id": "v2-ch21"
    },
    {
      "title": "பக்தவத்சலனார் பாராட்டு",
      "startPage": 193,
      "endPage": 201,
      "id": "v2-ch22"
    },
    {
      "title": "ஆகஸ்ட் திங்களில்!",
      "startPage": 202,
      "endPage": 211,
      "id": "v2-ch23"
    },
    {
      "title": "களம் காண்பதிலும் கடமையாற்றுவதிலும்!",
      "startPage": 212,
      "endPage": 219,
      "id": "v2-ch24"
    },
    {
      "title": "பஞ்சாப் பயணம்",
      "startPage": 220,
      "endPage": 227,
      "id": "v2-ch25"
    },
    {
      "title": "நற்பணியாற்றிய நான்கு குழுக்கள்",
      "startPage": 228,
      "endPage": 233,
      "id": "v2-ch26"
    },
    {
      "title": "இறைவனுக்குப் பிடித்த பணி!",
      "startPage": 234,
      "endPage": 238,
      "id": "v2-ch27"
    },
    {
      "title": "அர்ச்சகர் சட்டம்",
      "startPage": 239,
      "endPage": 244,
      "id": "v2-ch28"
    },
    {
      "title": "ஐம்பெரும் முழக்கம்",
      "startPage": 245,
      "endPage": 252,
      "id": "v2-ch29"
    },
    {
      "title": "\"தமிழ் உணர்வும் தமிழக உரிமையும்\"",
      "startPage": 253,
      "endPage": 258,
      "id": "v2-ch30"
    },
    {
      "title": "கொள்கை வளர்ந்த நிலை",
      "startPage": 259,
      "endPage": 265,
      "id": "v2-ch31"
    },
    {
      "title": "மருத்துவமனையிலும் மறவாத மக்கள் பணி",
      "startPage": 266,
      "endPage": 280,
      "id": "v2-ch32"
    },
    {
      "title": "கொள்கையும் கட்டுப்பாடும்",
      "startPage": 281,
      "endPage": 288,
      "id": "v2-ch33"
    },
    {
      "title": "நாடாளுமன்ற - சட்டமன்றத் தேர்தல்",
      "startPage": 289,
      "endPage": 296,
      "id": "v2-ch34"
    },
    {
      "title": "1971 தேர்தல் களம்",
      "startPage": 297,
      "endPage": 302,
      "id": "v2-ch35"
    },
    {
      "title": "அமைச்சரவையில் எம்.ஜி.ஆர்?",
      "startPage": 303,
      "endPage": 308,
      "id": "v2-ch36"
    },
    {
      "title": "மூன்றாவது-கழக அமைச்சரவை",
      "startPage": 309,
      "endPage": 316,
      "id": "v2-ch37"
    },
    {
      "title": "மதுரையில் ஒரு விழா!",
      "startPage": 317,
      "endPage": 323,
      "id": "v2-ch38"
    },
    {
      "title": "பிறந்த நாள் பணிகள்",
      "startPage": 324,
      "endPage": 328,
      "id": "v2-ch39"
    },
    {
      "title": "சில சட்டங்கள்!",
      "startPage": 329,
      "endPage": 333,
      "id": "v2-ch40"
    },
    {
      "title": "\"டாக்டர்\" பட்டம்",
      "startPage": 334,
      "endPage": 339,
      "id": "v2-ch41"
    },
    {
      "title": "அமெரிக்கப் பயணம்",
      "startPage": 340,
      "endPage": 345,
      "id": "v2-ch42"
    },
    {
      "title": "பாகிஸ்தான் ஆக்ரமிப்புக் கண்டனம்",
      "startPage": 346,
      "endPage": 351,
      "id": "v2-ch43"
    },
    {
      "title": "வங்கதேச உதயம்",
      "startPage": 352,
      "endPage": 359,
      "id": "v2-ch44"
    },
    {
      "title": "துரோகத்தின் தொடக்கம்!",
      "startPage": 360,
      "endPage": 367,
      "id": "v2-ch45"
    },
    {
      "title": "புயல் புகுமுன்!",
      "startPage": 368,
      "endPage": 375,
      "id": "v2-ch46"
    },
    {
      "title": "கட்டுப்பாடு மீறிய காரியங்கள்",
      "startPage": 376,
      "endPage": 384,
      "id": "v2-ch47"
    },
    {
      "title": "செயற்குழுவின் சீற்றம்",
      "startPage": 385,
      "endPage": 390,
      "id": "v2-ch48"
    },
    {
      "title": "வேறு வழியில்லை; விலக்கப்பட்டார்!",
      "startPage": 391,
      "endPage": 397,
      "id": "v2-ch49"
    },
    {
      "title": "\"இதுசத்தியம்\" என்றால்!",
      "startPage": 398,
      "endPage": 402,
      "id": "v2-ch50"
    },
    {
      "title": "திகைக்கவில்லை தித்திப்பு வழங்கினார்!",
      "startPage": 403,
      "endPage": 409,
      "id": "v2-ch51"
    },
    {
      "title": "சட்டமன்ற மரபுகளை வெட்டிப் புதைத்த செயல்!",
      "startPage": 410,
      "endPage": 425,
      "id": "v2-ch52"
    },
    {
      "title": "தஞ்சையும்-பூம்புகாரும்!",
      "startPage": 426,
      "endPage": 442,
      "id": "v2-ch53"
    },
    {
      "title": "கட்டபொம்மன் கோட்டை",
      "startPage": 443,
      "endPage": 450,
      "id": "v2-ch54"
    },
    {
      "title": "பொதுவாழ்வில் ஒரு பொன்னாள்!",
      "startPage": 451,
      "endPage": 457,
      "id": "v2-ch55"
    },
    {
      "title": "தீர்மானம் நிறைவேறியது",
      "startPage": 458,
      "endPage": 466,
      "id": "v2-ch56"
    },
    {
      "title": "இராமனுக்கு விரோதி யார்?",
      "startPage": 467,
      "endPage": 474,
      "id": "v2-ch57"
    },
    {
      "title": "ஜெ. பி. பாராட்டு!",
      "startPage": 475,
      "endPage": 482,
      "id": "v2-ch58"
    },
    {
      "title": "நெருக்கடி நிலைப் பிரகடனம்",
      "startPage": 483,
      "endPage": 489,
      "id": "v2-ch59"
    },
    {
      "title": "இந்தியாவிலேயே முதல் தீர்மானம்!",
      "startPage": 490,
      "endPage": 494,
      "id": "v2-ch60"
    },
    {
      "title": "காமராஜரின் கண்ணீரும் கடற்கரை சூளுரையும்!",
      "startPage": 495,
      "endPage": 497,
      "id": "v2-ch61"
    },
    {
      "title": "அந்தக் கூட்டத்தில் நான் உரையாற்றும் போது கூறியதாவது:-",
      "startPage": 498,
      "endPage": 502,
      "id": "v2-ch62"
    },
    {
      "title": "கடமை வீரரும் கர்ம வீரரும் மறைந்தனர்!",
      "startPage": 503,
      "endPage": 510,
      "id": "v2-ch63"
    },
    {
      "title": "காமராஜர் நினைவு போற்றிய கழகம்",
      "startPage": 511,
      "endPage": 515,
      "id": "v2-ch64"
    },
    {
      "title": "கோவை மாநாடும் சண்டிகர் மாநாடும்",
      "startPage": 516,
      "endPage": 524,
      "id": "v2-ch65"
    },
    {
      "title": "இந்தியாவில் இரு தீவுகள்",
      "startPage": 525,
      "endPage": 539,
      "id": "v2-ch66"
    },
    {
      "title": "கழக ஆட்சி கலைக்கப்பட்டது!",
      "startPage": 540,
      "endPage": 546,
      "id": "v2-ch67"
    },
    {
      "title": "அடக்குமுறை அடுக்கடுக்காக!",
      "startPage": 547,
      "endPage": 551,
      "id": "v2-ch68"
    },
    {
      "title": "கோவை, நீலகிரி மாவட்டங்கள்",
      "startPage": 552,
      "endPage": 553,
      "id": "v2-ch69"
    },
    {
      "title": "சட்டங்கள் பட்டபாடு!",
      "startPage": 554,
      "endPage": 560,
      "id": "v2-ch70"
    },
    {
      "title": "தடைபட்ட பயணம்!",
      "startPage": 561,
      "endPage": 567,
      "id": "v2-ch71"
    },
    {
      "title": "வேதனைக் காட்டில் சோதனைத் தீ!",
      "startPage": 568,
      "endPage": 579,
      "id": "v2-ch72"
    },
    {
      "title": "அண்ணா சாலையில் ஓர் அறப்போர்!",
      "startPage": 580,
      "endPage": 584,
      "id": "v2-ch73"
    },
    {
      "title": "வழக்குகள் தொடங்கின!",
      "startPage": 585,
      "endPage": 589,
      "id": "v2-ch74"
    },
    {
      "title": "இந்திரா காந்தி இறங்கி வந்தார்",
      "startPage": 590,
      "endPage": 594,
      "id": "v2-ch75"
    },
    {
      "title": "புதுடெல்லியில் ஒரு புதிய முயற்சி!",
      "startPage": 595,
      "endPage": 601,
      "id": "v2-ch76"
    },
    {
      "title": "இரண்டாம் பாகம் முற்றுப் பெறுகிறது!",
      "startPage": 602,
      "endPage": 608,
      "id": "v2-ch77"
    }
  ]
}