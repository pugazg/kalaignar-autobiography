{
 "note": "Human-verified letter facts for volume 54. Correct titles and fill dates against the printed volume/TOC; empty strings are ignored. Re-run the splitter after editing.",
 "letters": {
  "m54-l4016": {
   "number": 4016,
   "title": {
    "en": "Letter 4016",
    "ta": "தேர்தல் கமிஷனா? தில்லுமுல்லு செய்யும் கமிஷனா?"
   },
   "date": "2016-05-22",
   "pages": "m54-p0024..m54-p0031"
  },
  "m54-l4017": {
   "number": 4017,
   "title": {
    "en": "Letter 4017",
    "ta": "சென்னை மக்களுக்குச் சஞ்சலம்: ஜெயாவுக்கோ சந்தோஷம்"
   },
   "date": "",
   "pages": "m54-p0032..m54-p0040"
  },
  "m54-l4018": {
   "number": 4018,
   "title": {
    "en": "Letter 4018",
    "ta": "கச்சத் தீவு பற்றி ஜெயலலிதாவின் கருத்துக்கு மறுப்பு"
   },
   "date": "2016-06-22",
   "pages": "m54-p0041..m54-p0052"
  },
  "m54-l4019": {
   "number": 4019,
   "title": {
    "en": "Letter 4019",
    "ta": "சட்டமன்றம் நடந்தது; ஜனநாயகம் இருந்ததா?"
   },
   "date": "2016-06-24",
   "pages": "m54-p0053..m54-p0059"
  },
  "m54-l4020": {
   "number": 4020,
   "title": {
    "en": "Letter 4020",
    "ta": "பட்டுக்கோட்டைக்கு வழி எது என்று கேட்டால்..."
   },
   "date": "2016-06-25",
   "pages": "m54-p0060..m54-p0069"
  },
  "m54-l4021": {
   "number": 4021,
   "title": {
    "en": "Letter 4021",
    "ta": "சொத்துக் குவிப்பு வழக்கில் - சில குறிப்புகள்"
   },
   "date": "2016-06-28",
   "pages": "m54-p0070..m54-p0081"
  },
  "m54-l4022": {
   "number": 4022,
   "title": {
    "en": "Letter 4022",
    "ta": "இதுதான் ௮.தி.மு.க. அரசின் நிர்வாகத் திறமைக்குச் சாட்சியா?"
   },
   "date": "",
   "pages": "m54-p0082..m54-p0087"
  },
  "m54-l4023": {
   "number": 4023,
   "title": {
    "en": "Letter 4023",
    "ta": "அ.தி.மு.க. அரசுக்கு ஐகோர்ட் வழங்கிய மற்றொரு ஆணை"
   },
   "date": "2016-07-04",
   "pages": "m54-p0088..m54-p0093"
  },
  "m54-l4024": {
   "number": 4024,
   "title": {
    "en": "Letter 4024",
    "ta": "பொது சிவில் சட்டத்தைக் கொண்டுவர முயற்சியா?"
   },
   "date": "",
   "pages": "m54-p0094..m54-p0099"
  },
  "m54-l4025": {
   "number": 4025,
   "title": {
    "en": "Letter 4025",
    "ta": "570 கோடி சி.பி.ஐ முன்"
   },
   "date": "",
   "pages": "m54-p0100..m54-p0118"
  },
  "m54-l4026": {
   "number": 4026,
   "title": {
    "en": "Letter 4026",
    "ta": "நிதி எங்கே போகிறது?"
   },
   "date": "2016-07-18",
   "pages": "m54-p0119..m54-p0126"
  },
  "m54-l4027": {
   "number": 4027,
   "title": {
    "en": "Letter 4027",
    "ta": "மத்திய - மாநில உறவுகளில்"
   },
   "date": "",
   "pages": "m54-p0127..m54-p0135"
  },
  "m54-l4028": {
   "number": 4028,
   "title": {
    "en": "Letter 4028",
    "ta": "தமிழக அரசின் நிதிநிலை ௮றிக்கை காகிதப் பூ: கானல் நீர்"
   },
   "date": "2016-07-23",
   "pages": "m54-p0136..m54-p0145"
  },
  "m54-l4029": {
   "number": 4029,
   "title": {
    "en": "Letter 4029",
    "ta": "புதிய கல்விக் கொள்கை மாநிலங்களுக்குப் பொருந்துமா?"
   },
   "date": "",
   "pages": "m54-p0146..m54-p0154"
  },
  "m54-l4030": {
   "number": 4030,
   "title": {
    "en": "Letter 4030",
    "ta": "மெட்ரோ ரெயில் வந்தாச்சு: மோனோ ரயில் என்னாச்சு?"
   },
   "date": "",
   "pages": "m54-p0155..m54-p0163"
  },
  "m54-l4031": {
   "number": 4031,
   "title": {
    "en": "Letter 4031",
    "ta": "காவல் துறையினரைய் பாதுகாக்க ஜெயா கண்ணசைப்பாரா?"
   },
   "date": "",
   "pages": "m54-p0164..m54-p0169"
  },
  "m54-l4032": {
   "number": 4032,
   "title": {
    "en": "Letter 4032",
    "ta": "உதய் திட்டத்தை ஜெயலலிதா ஒப்புக்கொண்டுவிட்டாரா?"
   },
   "date": "2016-07-31",
   "pages": "m54-p0170..m54-p0176"
  },
  "m54-l4033": {
   "number": 4033,
   "title": {
    "en": "Letter 4033",
    "ta": "நிதி அமைச்சரின் பதிலுரை: நீர்த்துப் போன உரை"
   },
   "date": "",
   "pages": "m54-p0177..m54-p0184"
  },
  "m54-l4034": {
   "number": 4034,
   "title": {
    "en": "Letter 4034",
    "ta": "மின்வாரியம் குட்டிச்சுவரானது அ.தி.மு.க. ஆட்சியில்தான்"
   },
   "date": "",
   "pages": "m54-p0185..m54-p0195"
  },
  "m54-l4035": {
   "number": 4035,
   "title": {
    "en": "Letter 4035",
    "ta": "மதுவிலக்கில் உண்மையான அக்கறை யாருக்கு?"
   },
   "date": "2016-08-06",
   "pages": "m54-p0196..m54-p0205"
  },
  "m54-l4036": {
   "number": 4036,
   "title": {
    "en": "Letter 4036",
    "ta": "எழுத்துலகில் என்றும் வாழ்வார் என்னரும் நண்பர் சாவி"
   },
   "date": "2016-08-09",
   "pages": "m54-p0206..m54-p0211"
  },
  "m54-l4037": {
   "number": 4037,
   "title": {
    "en": "Letter 4037",
    "ta": "என் முதல் பிள்ளை முரசொலிக்கு இது பவள விழா ஆண்டு"
   },
   "date": "2016-08-10",
   "pages": "m54-p0212..m54-p0219"
  },
  "m54-l4038": {
   "number": 4038,
   "title": {
    "en": "Letter 4038",
    "ta": "எந்த ஆட்சியில் மகளிர்க்கு இட ஒதுக்கீடு?"
   },
   "date": "",
   "pages": "m54-p0220..m54-p0227"
  },
  "m54-l4039": {
   "number": 4039,
   "title": {
    "en": "Letter 4039",
    "ta": "110வது விதியின்கீழ் அறிக்கையும், அதற்கு விளக்கமும்"
   },
   "date": "2016-08-17",
   "pages": "m54-p0228..m54-p0236"
  },
  "m54-l4040": {
   "number": 4040,
   "title": {
    "en": "Letter 4040",
    "ta": "விவசாயிகளுக்கு ஜெயலலிதாவின் அறிவிப்பு வெறும் கண் துடைப்பு"
   },
   "date": "2016-08-20",
   "pages": "m54-p0237..m54-p0243"
  },
  "m54-l4041": {
   "number": 4041,
   "title": {
    "en": "Letter 4041",
    "ta": "தமிழகச் சட்டமன்றத்தில் ஜனநாயகம் படும் பாடு"
   },
   "date": "2016-08-21",
   "pages": "m54-p0244..m54-p0253"
  },
  "m54-l4042": {
   "number": 4042,
   "title": {
    "en": "Letter 4042",
    "ta": "அ.தி.மு.க. ஆட்சியில் சட்டம் ஒழுங்கு இலட்சணம்"
   },
   "date": "2016-08-22",
   "pages": "m54-p0254..m54-p0266"
  },
  "m54-l4043": {
   "number": 4043,
   "title": {
    "en": "Letter 4043",
    "ta": "நிலைகுலைந்த ஆட்சி - நிரந்தர வீழ்ச்சி! ஜெயா தலைமையில் 100 நாள் வேதனைகள்"
   },
   "date": "2016-09-02",
   "pages": "m54-p0267..m54-p0275"
  },
  "m54-l4044": {
   "number": 4044,
   "title": {
    "en": "Letter 4044",
    "ta": "தலைமைக் கணக்காயர் பட்டியலிடும் தவறுகள் - இழப்புகள்"
   },
   "date": "",
   "pages": "m54-p0276..m54-p0287"
  },
  "m54-l4045": {
   "number": 4045,
   "title": {
    "en": "Letter 4045",
    "ta": "வெண்ணெய் கையிலே இருக்கும்போது நெய்க்கு அலைவதா?"
   },
   "date": "2016-09-15",
   "pages": "m54-p0288..m54-p0294"
  },
  "m54-l4046": {
   "number": 4046,
   "title": {
    "en": "Letter 4046",
    "ta": "சூளுரை மேற்கொள்ள முப்பெரும் விழா துணைபுரியட்டும்"
   },
   "date": "2016-09-16",
   "pages": "m54-p0295..m54-p0304"
  },
  "m54-l4047": {
   "number": 4047,
   "title": {
    "en": "Letter 4047",
    "ta": "உள்ளாட்சித் தேர்தலில் உற்சாகத்துடன் அழைத்திடுக"
   },
   "date": "2016-09-28",
   "pages": "m54-p0305..m54-p0311"
  },
  "m54-l4048": {
   "number": 4048,
   "title": {
    "en": "Letter 4048",
    "ta": "காவிரிப் பிரச்சனை: பிரதமர் மோடி - சோனியா காந்தி தலையிட வேண்டும்"
   },
   "date": "2016-10-04",
   "pages": "m54-p0312..m54-p0318"
  },
  "m54-l4049": {
   "number": 4049,
   "title": {
    "en": "Letter 4049",
    "ta": "தமிழக மக்களின் அவசரத் தேவைகள் நிறைவேற"
   },
   "date": "2016-10-12",
   "pages": "m54-p0319..m54-p0326"
  },
  "m54-l4050": {
   "number": 4050,
   "title": {
    "en": "Letter 4050",
    "ta": "காவிரிப் பிரச்சினையில் கழகம் எடுத்த தொடர் நடவடிக்கைகள்"
   },
   "date": "2016-10-02",
   "pages": "m54-p0327..m54-p0336"
  },
  "m54-l4051": {
   "number": 4051,
   "title": {
    "en": "Letter 4051",
    "ta": "மத்திய அரசின் அறிவிப்பும், சாதாரண மக்களின் அவதியும்"
   },
   "date": "",
   "pages": "m54-p0337..m54-p0346"
  }
 }
