{
  "volume": 5,
  "strategy": "numbered",
  "totalPages": 1039,
  "chapterCount": 50,
  "chapters": [
    {
      "title": "ஓய்வுக்கு ஓய்வு",
      "startPage": 20,
      "endPage": 43,
      "id": "v5-ch01"
    },
    {
      "title": "அம்பேத்கர் கண்ட வழி",
      "startPage": 44,
      "endPage": 63,
      "id": "v5-ch02"
    },
    {
      "title": "சூப்பர் ஸ்டார் சூளுரை",
      "startPage": 64,
      "endPage": 81,
      "id": "v5-ch03"
    },
    {
      "title": "மதுவிலக்கு மாயை",
      "startPage": 82,
      "endPage": 97,
      "id": "v5-ch04"
    },
    {
      "title": "கறுப்பு நாள்",
      "startPage": 98,
      "endPage": 117,
      "id": "v5-ch05"
    },
    {
      "title": "நேபாளத்தில் ஒரு பூபாளம்",
      "startPage": 118,
      "endPage": 136,
      "id": "v5-ch06"
    },
    {
      "title": "பழி போட்டு வளர்த்த பகை",
      "startPage": 137,
      "endPage": 154,
      "id": "v5-ch07"
    },
    {
      "title": "காவியக் கருவூலம்",
      "startPage": 155,
      "endPage": 180,
      "id": "v5-ch08"
    },
    {
      "title": "திராவிடப் பல்கலைக் கழகம்",
      "startPage": 181,
      "endPage": 200,
      "id": "v5-ch09"
    },
    {
      "title": "கறுப்பு நிலாவும், கலைவாணர் நினைவும்!",
      "startPage": 201,
      "endPage": 222,
      "id": "v5-ch10"
    },
    {
      "title": "சென்னைக்குக் கிருஷ்ணா!",
      "startPage": 223,
      "endPage": 242,
      "id": "v5-ch11"
    },
    {
      "title": "கரும்பு தேசத்து இரும்பு மனிதன்!",
      "startPage": 243,
      "endPage": 261,
      "id": "v5-ch12"
    },
    {
      "title": "அன்பும் கருணையும்",
      "startPage": 262,
      "endPage": 283,
      "id": "v5-ch13"
    },
    {
      "title": "மறைந்த மாமணிகள்!",
      "startPage": 284,
      "endPage": 303,
      "id": "v5-ch14"
    },
    {
      "title": "ஜெயின் கமிஷன்",
      "startPage": 304,
      "endPage": 322,
      "id": "v5-ch15"
    },
    {
      "title": "சிங்காரவேலர் மாளிகை",
      "startPage": 323,
      "endPage": 343,
      "id": "v5-ch16"
    },
    {
      "title": "நடுநிலை தவறாத நல்லாட்சி!",
      "startPage": 344,
      "endPage": 363,
      "id": "v5-ch17"
    },
    {
      "title": "நிவாரணம் வழங்கிட நீதிபதி",
      "startPage": 364,
      "endPage": 384,
      "id": "v5-ch18"
    },
    {
      "title": "மனித நேயம் வளர்த்திட!",
      "startPage": 385,
      "endPage": 405,
      "id": "v5-ch19"
    },
    {
      "title": "மாறனும்,மாநில சுயாட்சியும்!",
      "startPage": 406,
      "endPage": 425,
      "id": "v5-ch20"
    },
    {
      "title": "பூனைக் குட்டியும், யானையும்!",
      "startPage": 426,
      "endPage": 448,
      "id": "v5-ch21"
    },
    {
      "title": "ஒட்டு மாங்கனி",
      "startPage": 449,
      "endPage": 466,
      "id": "v5-ch22"
    },
    {
      "title": "கலைத்துறையினர் பிரச்சினையும் - காட்டு வீரப்பன் தேடலும்!",
      "startPage": 467,
      "endPage": 487,
      "id": "v5-ch23"
    },
    {
      "title": "தங்கமான தம்பி பாண்டியன்",
      "startPage": 488,
      "endPage": 507,
      "id": "v5-ch24"
    },
    {
      "title": "அன்னை தெரசாவும்,",
      "startPage": 508,
      "endPage": 532,
      "id": "v5-ch25"
    },
    {
      "title": "அண்ணாவே வந்து",
      "startPage": 533,
      "endPage": 552,
      "id": "v5-ch26"
    },
    {
      "title": "சாதனைச் சிகரம்; சமத்துவபுரம்!",
      "startPage": 553,
      "endPage": 573,
      "id": "v5-ch27"
    },
    {
      "title": "அலை மோதிய அரசியல்!",
      "startPage": 574,
      "endPage": 592,
      "id": "v5-ch28"
    },
    {
      "title": "சுய சொரூபம் வெளிப்பட்டது!",
      "startPage": 593,
      "endPage": 612,
      "id": "v5-ch29"
    },
    {
      "title": "ஆட்சியைக் கலைக்க ஆடிய ஆட்டம்",
      "startPage": 613,
      "endPage": 630,
      "id": "v5-ch30"
    },
    {
      "title": "\"கூனி மந்தரை\" என்று கூறியது",
      "startPage": 631,
      "endPage": 649,
      "id": "v5-ch31"
    },
    {
      "title": "சிறந்த நிர்வாகி-திரு.பக்தவத்சலம்!",
      "startPage": 650,
      "endPage": 671,
      "id": "v5-ch32"
    },
    {
      "title": "ஜீவாவும்- ஈ.எம்.எஸ்.ஸும்!",
      "startPage": 672,
      "endPage": 692,
      "id": "v5-ch33"
    },
    {
      "title": "மிகவும் பிற்படுத்தப்பட்டோர்க்கு",
      "startPage": 693,
      "endPage": 714,
      "id": "v5-ch34"
    },
    {
      "title": "கைக்கு எட்டியது... ஆனால்",
      "startPage": 715,
      "endPage": 733,
      "id": "v5-ch35"
    },
    {
      "title": "தாண்டிய தடைக்கற்கள்!",
      "startPage": 734,
      "endPage": 751,
      "id": "v5-ch36"
    },
    {
      "title": "கூறாததைக் கூறியதாக...",
      "startPage": 752,
      "endPage": 769,
      "id": "v5-ch37"
    },
    {
      "title": "ராஜரத்னா விருது!",
      "startPage": 770,
      "endPage": 789,
      "id": "v5-ch38"
    },
    {
      "title": "\"எதையும் வெல்லும் எழுத்து",
      "startPage": 790,
      "endPage": 810,
      "id": "v5-ch39"
    },
    {
      "title": "பீகாரும்-பெர்னாண்டசும்",
      "startPage": 811,
      "endPage": 830,
      "id": "v5-ch40"
    },
    {
      "title": "பொன்முடியின் புத்தகம்",
      "startPage": 831,
      "endPage": 852,
      "id": "v5-ch41"
    },
    {
      "title": "சோனியா காந்தியின் அரசியல்",
      "startPage": 853,
      "endPage": 871,
      "id": "v5-ch42"
    },
    {
      "title": "தமிழன்னைக்கு மகுடம்!",
      "startPage": 872,
      "endPage": 889,
      "id": "v5-ch43"
    },
    {
      "title": "மண்மீட்ட போராளிகளை மறக்க",
      "startPage": 890,
      "endPage": 910,
      "id": "v5-ch44"
    },
    {
      "title": "சிங்கை-மலேசியா நிகழ்ச்சிகள்!",
      "startPage": 911,
      "endPage": 931,
      "id": "v5-ch45"
    },
    {
      "title": "நிகழ்வுகளும் நினைவுகளும்!",
      "startPage": 932,
      "endPage": 950,
      "id": "v5-ch46"
    },
    {
      "title": "நம்ப முடியாதது;",
      "startPage": 951,
      "endPage": 972,
      "id": "v5-ch47"
    },
    {
      "title": "ஒரு வாக்கு வித்தியாசத்தில்",
      "startPage": 973,
      "endPage": 994,
      "id": "v5-ch48"
    },
    {
      "title": "ஏரி உடைப்பும்; என் கடமையும்!",
      "startPage": 995,
      "endPage": 1014,
      "id": "v5-ch49"
    },
    {
      "title": "ஆறாம் பாகம் ஆரம்பமாகும்!",
      "startPage": 1015,
      "endPage": 1039,
      "id": "v5-ch50"
    }
  ]
}