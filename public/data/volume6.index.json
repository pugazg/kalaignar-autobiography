      "endPage": 257,
      "id": "v6-ch13"
    },
    {
      "title": "அன்றே ஆரம்பமான",
      "startPage": 258,
      "endPage": 276,
      "id": "v6-ch14"
    },
    {
      "title": "காரிருளில், காட்டாட்சி தர்பார்!",
      "startPage": 277,
      "endPage": 294,
      "id": "v6-ch15"
    },
    {
      "title": "\"நீ, எங்கிருந்தாலும் வாழ்க!\"",
      "startPage": 295,
      "endPage": 312,
      "id": "v6-ch16"
    },
    {
      "title": "நட்புக்கு இலக்கணம் -",
      "startPage": 313,
      "endPage": 331,
      "id": "v6-ch17"
    },
    {
      "title": "அரசியல் சட்டத்தையே மீறிய",
      "startPage": 332,
      "endPage": 349,
      "id": "v6-ch18"
    },
    {
      "title": "கண்ணகிமீது ஏனிந்தக் காழ்ப்பு?",
      "startPage": 350,
      "endPage": 366,
      "id": "v6-ch19"
    },
    {
      "title": "அய்யோத் - தீ!",
      "startPage": 367,
      "endPage": 385,
      "id": "v6-ch20"
    },
    {
      "title": "மஞ்சள் சால்வைக்கு மகத்துவம்",
      "startPage": 386,
      "endPage": 403,
      "id": "v6-ch21"
    },
    {
      "title": "வெற்றியுமல்ல - தோல்வியுமல்ல!",
      "startPage": 404,
      "endPage": 419,
      "id": "v6-ch22"
    },
    {
      "title": "சேது சமுத்திரத் திட்டம் ஏன்?",
      "startPage": 420,
      "endPage": 437,
      "id": "v6-ch23"
    },
    {
      "title": "ஜெயா ஆட்சியில்",
      "startPage": 438,
      "endPage": 455,
      "id": "v6-ch24"
    },
    {
      "title": "எந்த நாளும் மறவாத",
      "startPage": 456,
      "endPage": 475,
      "id": "v6-ch25"
    },
    {
      "title": "என்றும் மறக்க முடியாத மாறன்!",
      "startPage": 476,
      "endPage": 493,
      "id": "v6-ch26"
    },
    {
      "title": "\"தொல்காப்பிய பூங்கா\"",
      "startPage": 494,
      "endPage": 513,
      "id": "v6-ch27"
    },
    {
      "title": "நீதியே; நீ இன்னும்",
      "startPage": 514,
      "endPage": 532,
      "id": "v6-ch28"
    },
    {
      "title": "இயற்கையின் துணையை நம்பி!",
